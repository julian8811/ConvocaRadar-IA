# Frontend
NEXT_PUBLIC_API_URL=https://api.convocaradar.com/api/v1
FRONTEND_URL=https://convocaradar.com

# Backend / API
APP_ENV=production
APP_NAME=ConvocaRadar IA
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/convocaradar
REDIS_URL=rediss://:PASSWORD@HOST:PORT/0
JWT_SECRET=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
USE_WORKER=true
INTERNAL_API_KEY=replace_with_a_second_long_random_secret
LLM_PROVIDER=mock
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4.1-mini
STORAGE_BACKEND=s3
STORAGE_DIR=./storage
MAX_UPLOAD_BYTES=10000000
S3_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY=replace_with_r2_access_key
S3_SECRET_KEY=replace_with_r2_secret_key
S3_BUCKET=convocaradar
S3_REGION=auto
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@convocaradar.com
SMTP_USE_TLS=true
SCRAPING_USER_AGENT=ConvocaRadarBot/0.1
SCRAPING_TIMEOUT_SECONDS=30
SCRAPING_MAX_SOURCE_SECONDS=90
SCRAPING_MAX_CONCURRENCY=5
SCRAPING_CLOSING_SOON_DAYS=10
SCRAPING_EXECUTION_MODE=inline
USE_WORKER=false
BACKEND_URL=https://api.convocaradar.com
