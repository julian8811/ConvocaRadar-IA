{
  "name": "convocaradar",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "dependencies": {
    "eslint-config-next": "latest"
  },
  "scripts": {
    "dev:web": "pnpm --filter @convocaradar/web dev",
    "build:web": "pnpm --filter @convocaradar/web build",
    "lint:web": "pnpm --filter @convocaradar/web lint",
    "test:web": "pnpm --filter @convocaradar/web test",
    "build": "pnpm build:web",
    "postbuild": "node scripts/sync-next-output.mjs",
    "lint": "pnpm lint:web",
    "test": "pnpm test:web && pnpm test:api",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "test:api": "cd apps/api && pytest",
    "migrate:api": "cd apps/api && python -m alembic upgrade head",
    "seed:api": "cd apps/api && python -m app.db.seed"
  }
}
