APP_ENV=development
APP_NAME=ConvocaRadar IA
DATABASE_URL=sqlite:///./convocaradar.db
POSTGRES_DATABASE_URL=postgresql+psycopg://convocaradar:convocaradar@postgres:5432/convocaradar
REDIS_URL=redis://localhost:6379/0
# Must be at least 32 characters
JWT_SECRET=change_me_must_be_32_chars_placeholder_
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
USE_WORKER=false
# Must be at least 32 characters
INTERNAL_API_KEY=change_me_internal_must_be_32_chars_
LLM_PROVIDER=local
OPENAI_API_KEY=
EMBEDDING_MODEL=
CHAT_MODEL=
BOOTSTRAP_SOURCES_ON_STARTUP=true
BOOTSTRAP_SOURCES_BLOCKING=false
BOOTSTRAP_SOURCE_KEYS=grants-gov-rss,grants-gov,innpulsa,minciencias,nsf-funding-rss
SENTRY_DSN=
STORAGE_BACKEND=local
STORAGE_DIR=./storage
MAX_UPLOAD_BYTES=10000000
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=convocaradar
S3_REGION=us-east-1
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@convocaradar.local
SMTP_USE_TLS=true
SCRAPING_USER_AGENT=ConvocaRadarBot/0.1
SCRAPING_TIMEOUT_SECONDS=30
SCRAPING_MAX_SOURCE_SECONDS=90
SCRAPING_MAX_CONCURRENCY=5
SCRAPING_CLOSING_SOON_DAYS=10
SCRAPING_EXECUTION_MODE=inline
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Frontend environment marker (SEC-1.3). Set to "production" in production
# builds to hide the dev-credentials helper. The web build defaults to
# "development" locally; CI sets it to "production".
NEXT_PUBLIC_ENV=development

# Dev-only credentials (SEC-1.3). ONLY used when NEXT_PUBLIC_ENV is not
# "production". In production these must be empty / unset so no dev creds
# leak into the bundle. For local dev, copy the values below to
# apps/web/.env.development (gitignored).
NEXT_PUBLIC_LOCAL_EMAIL=dev@convocaradar.local
NEXT_PUBLIC_LOCAL_PASSWORD=change-me-for-local-dev-only
